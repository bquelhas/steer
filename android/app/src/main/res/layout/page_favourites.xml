<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- Which navigator opens when a favourite is picked ON THE WATCH -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/nav_app_label"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/nav_app_caption"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <!-- Clean settings-style dropdown: a tonal pill showing the current navigator with a
             chevron; tapping opens a popup menu of the five options (a horizontal toggle row
             truncates the labels). -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/navAppButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:fontFamily="sans-serif-condensed"
            android:textAllCaps="false"
            app:icon="@drawable/ic_arrow_drop_down"
            app:iconGravity="end" />

        <!-- Shown only for Organic Maps / CoMaps: their deep link can't auto-start navigation. -->
        <TextView
            android:id="@+id/navAppNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-condensed"
            android:visibility="gone"
            android:text="@string/nav_app_manual_start"
            android:textColor="?attr/colorPrimary"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantOverlay"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-condensed"
            android:visibility="gone"
            android:text="@string/overlay_grant" />

        <TextView
            android:id="@+id/overlayCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/overlay_caption"
            android:textAppearance="?attr/textAppearanceBodySmall" />

        <!-- Saved destinations (embedded CRUD) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/favorites_title"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFavorite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-condensed"
            app:icon="@android:drawable/ic_input_add"
            android:text="@string/fav_add" />

        <!-- RecyclerView (not a plain LinearLayout) so favourites can be reordered by
             long-press drag (ItemTouchHelper). Nested scrolling is disabled in code —
             the page's NestedScrollView owns the scroll. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/favoritesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/favEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-condensed"
            android:gravity="center"
            android:text="@string/fav_empty"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
